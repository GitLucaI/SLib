function Library:AddColorPicker(text, defaultColor, callback)
	local colorElement = Templates.Color:Clone()
	local currentColor = defaultColor or Color3.fromRGB(255, 255, 255)
	currentOrder = currentOrder + 1
	colorElement.LayoutOrder = currentOrder
	colorElement.TextLabel.Text = text
	colorElement.Visible = true
	colorElement.Parent = scroller
	local displayCircle = colorElement.Action.Button
	local function updateDisplay(color)
		currentColor = color
		displayCircle.BackgroundColor3 = color
		if displayCircle:FindFirstChild("UIGradient") then
			displayCircle.UIGradient.Enabled = false
		end
	end
	updateDisplay(currentColor)
	colorElement.Action.Button.MouseButton1Click:Connect(function()
		activeColorCallback = callback
		activeColorUpdate = updateDisplay
		cpTextboxes.R.Text = tostring(math.floor(currentColor.R * 255))
		cpTextboxes.G.Text = tostring(math.floor(currentColor.G * 255))
		cpTextboxes.B.Text = tostring(math.floor(currentColor.B * 255))
		colorPickerUI.Visible = true
	end)
	return colorElement
end

return Library
