function Library:AddTab(name, customOrder)
	local tabIndex = customOrder or totalTabsCount
	if not customOrder then totalTabsCount = totalTabsCount + 1 end

	local newTabButton = TabButtonTemplate:Clone()
	newTabButton.LayoutOrder = tabIndex
	if newTabButton:IsA("TextButton") then
		newTabButton.TextLabel.Text = name
	elseif newTabButton:FindFirstChild("TextLabel") then
		newTabButton.TextLabel.Text = name
	elseif newTabButton:FindFirstChild("Action") and newTabButton.Action:IsA("TextButton") then
		newTabButton.Action.Text = name
	end

	local buttonTrigger = newTabButton:IsA("TextButton") and newTabButton or newTabButton:FindFirstChildOfClass("TextButton") or newTabButton

	if not firstTabCreated then
		firstTabCreated = true
		buttonTrigger.BackgroundTransparency = 0.3
	else
		buttonTrigger.BackgroundTransparency = 1
	end

	newTabButton.Visible = true
	newTabButton.Parent = tabsListFrame

	local newTabFrame = TabTemplate:Clone()
	newTabFrame.LayoutOrder = tabIndex
	newTabFrame.Visible = true
	newTabFrame.Parent = tabsFrame

	buttonTrigger.MouseButton1Click:Connect(function()
		for _, child in pairs(tabsListFrame:GetChildren()) do
