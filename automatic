UIS.InputChanged:Connect(function(input)
	if draggingColor and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local center = cpPicker.AbsolutePosition + (cpPicker.AbsoluteSize / 2)
		local mousePos = Vector2.new(input.Position.X, input.Position.Y)
		local distance = (mousePos - center).Magnitude
		local radius = cpPicker.AbsoluteSize.X / 2
		if distance > radius then distance = radius end
		local delta = mousePos - center
		local angle = math.atan2(delta.Y, delta.X)
		local hue = ((-angle - math.pi / 2) / (math.pi * 2)) % 1
		local saturation = distance / radius
		local newColor = Color3.fromHSV(hue, saturation, 1)
		cpTextboxes.R.Text = tostring(math.floor(newColor.R * 255))
		cpTextboxes.G.Text = tostring(math.floor(newColor.G * 255))
		cpTextboxes.B.Text = tostring(math.floor(newColor.B * 255))
		if activeColorUpdate then activeColorUpdate(newColor) end
		if activeColorCallback then activeColorCallback(newColor) end
	end
end)

