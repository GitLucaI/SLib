	[Enum.KeyCode.D] = true,
	[Enum.KeyCode.Escape] = true,
	[Enum.KeyCode.Unknown] = true
}

UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.Delete then
		script.Parent.Visible = not script.Parent.Visible
	end
end)

if not UIS.TouchEnabled then
	script.Parent.Parent.ToggleUI.Visible = false
end

script.Parent:WaitForChild("Topbar").Minimize.MouseButton1Click:Connect(function()
	script.Parent.Visible = false
end)

script.Parent.Parent.ToggleUI.MouseButton1Click:Connect(function()
	script.Parent.Visible = not script.Parent.Visible
end)

colorPickerUI:WaitForChild("Close").MouseButton1Click:Connect(function()
	colorPickerUI.Visible = false
end)

cpPicker.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingColor = true
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingColor = false
	end
end)

UIS.InputChanged:Connect(function(input)
	if draggingColor and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local center = cpPicker.AbsolutePosition + (cpPicker.AbsoluteSize / 2)
		local mousePos = Vector2.new(input.Position.X, input.Position.Y)
		local distance = (mousePos - center).Magnitude
		local radius = cpPicker.AbsoluteSize.X / 2
		if distance > radius then distance = radius end
		local delta = mousePos - center
		local angle = math.atan2(delta.Y, delta.X)
		local hue = ((-angle - math.pi / 2) / (math.pi * 2)) % 1
		local saturation = distance / radius
		local newColor = Color3.fromHSV(hue, saturation, 1)
		cpTextboxes.R.Text = tostring(math.floor(newColor.R * 255))
		cpTextboxes.G.Text = tostring(math.floor(newColor.G * 255))
		cpTextboxes.B.Text = tostring(math.floor(newColor.B * 255))
		if activeColorUpdate then activeColorUpdate(newColor) end
		if activeColorCallback then activeColorCallback(newColor) end
	end
end)

local function updateFromTextBoxes()
	local r = math.clamp(tonumber(cpTextboxes.R.Text) or 255, 0, 255)
	local g = math.clamp(tonumber(cpTextboxes.G.Text) or 255, 0, 255)
	local b = math.clamp(tonumber(cpTextboxes.B.Text) or 255, 0, 255)
	local newColor = Color3.fromRGB(r, g, b)
	if activeColorUpdate then activeColorUpdate(newColor) end
	if activeColorCallback then activeColorCallback(newColor) end
end

cpTextboxes.R.FocusLost:Connect(updateFromTextBoxes)
cpTextboxes.G.FocusLost:Connect(updateFromTextBoxes)
cpTextboxes.B.FocusLost:Connect(updateFromTextBoxes)

local function setupKeybind(keybindObject, defaultKey, keybindCallback)
	local boundKey = defaultKey or nil
	local listening = false

	local function updateText()
		if boundKey then
			keybindObject.Text = boundKey.Name
		else
			keybindObject.Text = "NONE"
		end
	end
	updateText()

	keybindObject.MouseButton1Click:Connect(function()
		if listening then return end
		listening = true
		keybindObject.Text = "..."

		local connection
		connection = UIS.InputBegan:Connect(function(input, gpe)
			if input.UserInputType == Enum.UserInputType.Keyboard then
				connection:Disconnect()
				if input.KeyCode == Enum.KeyCode.Escape then
					boundKey = nil
				elseif blacklistedKeys[input.KeyCode] then
					updateText()
					task.wait()
					listening = false
					return
				else
					boundKey = input.KeyCode
				end
				updateText()
				if keybindCallback then keybindCallback(boundKey) end
				task.wait()
				listening = false
			elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
				connection:Disconnect()
				boundKey = nil
				updateText()
				if keybindCallback then keybindCallback(boundKey) end
				task.wait()
				listening = false
			end
		end)
	end)

	UIS.InputBegan:Connect(function(input, gpe)
		if gpe or listening then return end
		if boundKey and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == boundKey then
			if keybindCallback then keybindCallback(boundKey, true) end
		end
	end)
end

function Library:SetBackgroundTheme(colorsequence)
	for _, bgelem in pairs(CollectionService:GetTagged("SV2LIBBGELEMENT")) do
		bgelem.Color = colorsequence
	end
end

function Library:Notify(message)
	local notification = script.Parent.Parent.Notifications.Template:Clone()
	notification.Main.Content.Text = message
	notification.Visible = true
	notification.Parent = script.Parent.Parent.Notifications
	notification.Main:TweenPosition(UDim2.new(0, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Bounce, 1)
	task.wait(1)
	notification.Main.Close.MouseButton1Click:Connect(function()
		notification.Main:TweenPosition(UDim2.new(1.1, 0, 0, 0), Enum.EasingDirection.In, Enum.EasingStyle.Bounce, 1)
		task.wait(1)
		notification:Destroy()
	end)
	for i = 1, 15 do
		if not notification:FindFirstChild("Main") then break end
		notification.Main.Close.Text = "Okay (" .. (15 - i) .. ")"
		task.wait(1)
	end
	if notification:FindFirstChild("Main") then
		notification.Main:TweenPosition(UDim2.new(1.1, 0, 0, 0), Enum.EasingDirection.In, Enum.EasingStyle.Bounce, 1)
		task.wait(1)
		notification:Destroy()
	end
end

function Library:AddLabel(text)
	local label = Templates.Label:Clone()
	currentOrder = currentOrder + 1
	label.LayoutOrder = currentOrder
	label.TextLabel.Text = text
	label.Visible = true
	label.Parent = scroller
	return label
end

function Library:AddButton(text, callback, defaultKey, keybindCallback)
	local button = Templates.Button:Clone()
	currentOrder = currentOrder + 1
	button.LayoutOrder = currentOrder
	button.Action.Text = text
	button.Visible = true
	button.Parent = scroller
	button.Action.MouseButton1Click:Connect(function()
		if callback then
			callback()
		end
	end)
	if button:FindFirstChild("Keybind") then
		setupKeybind(button.Keybind, defaultKey, function(key, triggered)
			if triggered then
				if callback then callback() end
			elseif keybindCallback then
				keybindCallback(key)
			end
		end)
	end
	return button
end

function Library:AddToggle(text, defaultState, callback, defaultKey, keybindCallback)
	local toggleElement = Templates.Toggle:Clone()
	local currentState = defaultState or false
	local cd = false
	currentOrder = currentOrder + 1
	toggleElement.LayoutOrder = currentOrder
	toggleElement.TextLabel.Text = text
	toggleElement.Visible = true
	toggleElement.Parent = scroller

	local function fireToggle()
		if cd then return end
		cd = true
		currentState = not currentState
		if currentState then
			toggleElement.Action.Toggle:TweenPosition(UDim2.new(0.5, 0, 0, 0), Enum.EasingDirection.In, Enum.EasingStyle.Linear, 0.125)
		else
			toggleElement.Action.Toggle:TweenPosition(UDim2.new(0, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Linear, 0.125)
		end
		if callback then
			callback(currentState)
		end
		wait(0.25)
		cd = false
	end

	toggleElement.Action.Toggle.MouseButton1Click:Connect(fireToggle)
	if toggleElement:FindFirstChild("Keybind") then
		setupKeybind(toggleElement.Keybind, defaultKey, function(key, triggered)
			if triggered then
				fireToggle()
			elseif keybindCallback then
				keybindCallback(key)
			end
		end)
	end
	return toggleElement
end

