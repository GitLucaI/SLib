			end
		end
		buttonTrigger.BackgroundTransparency = 0.3

		local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Linear, Enum.EasingDirection.In)
		local tween = TweenService:Create(tabsFrame, tweenInfo, {CanvasPosition = Vector2.new(tabsFrame.AbsoluteSize.X * tabIndex, 0)})
