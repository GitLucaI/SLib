function Library:AddToggle(tab, text, defaultState, callback, defaultKey, keybindCallback)
	local toggleElement = Templates.Toggle:Clone()
	local currentState = defaultState or false
	local cd = false
	currentOrder = currentOrder + 1
	toggleElement.LayoutOrder = currentOrder
	toggleElement.TextLabel.Text = text
	toggleElement.Visible = true
	toggleElement.Parent = tab

	if isSavingEnabled and savedData[text] ~= nil then
		currentState = savedData[text]
	else
		currentState = defaultState or false
	end

	local function setVisualState(state)
		if state then
			toggleElement.Action.Toggle:TweenPosition(UDim2.new(0.5, 0, 0, 0), Enum.EasingDirection.In, Enum.EasingStyle.Linear, 0.125)
		else
			toggleElement.Action.Toggle:TweenPosition(UDim2.new(0, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Linear, 0.125)
		end
	end

	setVisualState(currentState)
	if currentState and callback then
		task.spawn(function() callback(currentState) end)
	end

	local function fireToggle()
		if cd then return end
		cd = true
		currentState = not currentState
		setVisualState(currentState)
		if isSavingEnabled then
			savedData[text] = currentState
			saveData()
		end
		if callback then
			callback(currentState)
		end
		wait(0.25)
		cd = false
	end

	toggleElement.Action.Toggle.MouseButton1Click:Connect(fireToggle)

	local bindSaveName = text .. "_Keybind"
	local currentKey = defaultKey
	if isSavingEnabled and savedData[bindSaveName] ~= nil then
		currentKey = Enum.KeyCode[savedData[bindSaveName]]
	end

	if toggleElement:FindFirstChild("Keybind") then
		setupKeybind(toggleElement.Keybind, currentKey, function(key, triggered)
			if not triggered and key then
				if isSavingEnabled then
					savedData[bindSaveName] = key.Name
					saveData()
				end
			end
			if triggered then
				fireToggle()
			elseif keybindCallback then
				keybindCallback(key)
			end
		end)
	end
	return toggleElement
end

