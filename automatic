function Library:AddGradientPicker(tab, text, defaultStartColor, defaultEndColor, callback)
	local gradientElement = Templates.Gradient:Clone()
	currentOrder = currentOrder + 1
	gradientElement.LayoutOrder = currentOrder
	gradientElement.TextLabel.Text = text
	gradientElement.Visible = true
	gradientElement.Parent = tab

	local isGlobalTheme = (text == "UI Theme")
	local startColor = defaultStartColor or Color3.fromRGB(74, 86, 111)
	local endColor = defaultEndColor or Color3.fromRGB(73, 58, 86)

	if isGlobalTheme and globalData[text] ~= nil then
		local savedGrad = globalData[text]
		startColor = Color3.fromRGB(savedGrad.Start.R, savedGrad.Start.G, savedGrad.Start.B)
		endColor = Color3.fromRGB(savedGrad.End.R, savedGrad.End.G, savedGrad.End.B)
	elseif not isGlobalTheme and isSavingEnabled and savedData[text] ~= nil then
		local savedGrad = savedData[text]
		startColor = Color3.fromRGB(savedGrad.Start.R, savedGrad.Start.G, savedGrad.Start.B)
		endColor = Color3.fromRGB(savedGrad.End.R, savedGrad.End.G, savedGrad.End.B)
	end

	local function updateGradient()
		local seq = ColorSequence.new{
			ColorSequenceKeypoint.new(0.0, startColor),
			ColorSequenceKeypoint.new(1.0, endColor)
		}
		if callback then callback(seq) end

		local colorData = {
			Start = {R = math.floor(startColor.R * 255), G = math.floor(startColor.G * 255), B = math.floor(startColor.B * 255)},
			End = {R = math.floor(endColor.R * 255), G = math.floor(endColor.G * 255), B = math.floor(endColor.B * 255)}
		}

		if isGlobalTheme then
			globalData[text] = colorData
			saveGlobal()
		elseif isSavingEnabled then
			savedData[text] = colorData
			saveData()
		end
	end

	gradientElement.Action1.Button.MouseButton1Click:Connect(function()
		activeColorCallback = function(color)
			startColor = color
			gradientElement.Action1.Button.BackgroundColor3 = color
			updateGradient()
		end
		activeColorUpdate = function(color)
			gradientElement.Action1.Button.BackgroundColor3 = color
		end
		cpTextboxes.R.Text = tostring(math.floor(startColor.R * 255))
		cpTextboxes.G.Text = tostring(math.floor(startColor.G * 255))
		cpTextboxes.B.Text = tostring(math.floor(startColor.B * 255))
		colorPickerUI.Visible = true
	end)

	gradientElement.Action2.Button.MouseButton1Click:Connect(function()
		activeColorCallback = function(color)
			endColor = color
			gradientElement.Action2.Button.BackgroundColor3 = color
			updateGradient()
		end
		activeColorUpdate = function(color)
			gradientElement.Action2.Button.BackgroundColor3 = color
		end
		cpTextboxes.R.Text = tostring(math.floor(endColor.R * 255))
		cpTextboxes.G.Text = tostring(math.floor(endColor.G * 255))
		cpTextboxes.B.Text = tostring(math.floor(endColor.B * 255))
		colorPickerUI.Visible = true
	end)

	gradientElement.Action1.Button.BackgroundColor3 = startColor
	gradientElement.Action2.Button.BackgroundColor3 = endColor

	if isGlobalTheme and globalData[text] ~= nil and callback then
		task.spawn(updateGradient)
	elseif not isGlobalTheme and isSavingEnabled and savedData[text] ~= nil and callback then
		task.spawn(updateGradient)
	end

	return gradientElement
end

